# Lily58 split keyboard — default configuration values
#
# Only set defaults for symbols that ZMK already declares with a type.
# BT profiles, USB, sleep timeout etc. belong in config/lily58.conf.

if SHIELD_LILY58_LEFT || SHIELD_LILY58_RIGHT

config ZMK_KEYBOARD_NAME
	default "Lily58"

config ZMK_SPLIT
	default y

endif # SHIELD_LILY58_LEFT || SHIELD_LILY58_RIGHT

if SHIELD_LILY58_LEFT

config ZMK_SPLIT_ROLE_CENTRAL
	default y

endif # SHIELD_LILY58_LEFT
