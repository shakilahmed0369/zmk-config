/*
 * Lily58 hand-wired matrix for SuperMini NRF52840 (v1940)
 * Diode direction: col2row (Cathode/Black line toward the Row)
 */

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

default_transform: keymap_transform_0 {
    compatible = "zmk,matrix-transform";
    columns = <12>;
    rows = <5>;

    map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)                         RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)                         RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)                         RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5) RC(4,5)         RC(4,6) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                        RC(4,1) RC(4,2) RC(4,3) RC(4,4)         RC(4,7) RC(4,8) RC(4,9) RC(4,10)
    >;
};

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        /* Row GPIOs - Mapped to labels: 100, 011, 104, 106, 009 */
        row-gpios
            = <&gpio1 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 0 - Label 100 */
            , <&gpio0 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 1 - Label 011 */
            , <&gpio1 4  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 2 - Label 104 */
            , <&gpio1 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 3 - Label 106 */
            , <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 4 - Label 009 */
            ;

        /* Column GPIOs - Mapped to labels: 031, 029, 002, 115, 113, 111 */
        col-gpios
            = <&gpio0 31 GPIO_ACTIVE_HIGH>   /* Col 0 - Label 031 */
            , <&gpio0 29 GPIO_ACTIVE_HIGH>   /* Col 1 - Label 029 */
            , <&gpio0 2  GPIO_ACTIVE_HIGH>   /* Col 2 - Label 002 */
            , <&gpio1 15 GPIO_ACTIVE_HIGH>   /* Col 3 - Label 115 */
            , <&gpio1 13 GPIO_ACTIVE_HIGH>   /* Col 4 - Label 113 */
            , <&gpio1 11 GPIO_ACTIVE_HIGH>   /* Col 5 - Label 111 */
            ;
    };
};