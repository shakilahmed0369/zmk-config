# Lily58 split keyboard — shield Kconfig
#
# Declares the SHIELD_LILY58_LEFT / SHIELD_LILY58_RIGHT bool symbols so they
# are visible to if-guards in Kconfig.defconfig and the rest of the build.

config SHIELD_LILY58_LEFT
	def_bool $(shields_list_contains,lily58_left)

config SHIELD_LILY58_RIGHT
	def_bool $(shields_list_contains,lily58_right)
