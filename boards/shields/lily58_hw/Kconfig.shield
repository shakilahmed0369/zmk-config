# Lily58 HW (hand-wired) split keyboard — shield Kconfig
#
# Declares the SHIELD_LILY58_HW_LEFT / SHIELD_LILY58_HW_RIGHT bool symbols so they
# are visible to if-guards in Kconfig.defconfig and the rest of the build.

config SHIELD_LILY58_HW_LEFT
	def_bool $(shields_list_contains,lily58_hw_left)

config SHIELD_LILY58_HW_RIGHT
	def_bool $(shields_list_contains,lily58_hw_right)
